{
    "schemes": [
        "http",
        "https"
    ],
    "swagger": "2.0",
    "info": {
        "description": "FastGo starter API documentation.",
        "title": "FastGo API",
        "contact": {},
        "version": "1.0"
    },
    "basePath": "/api",
    "paths": {
        "/health": {
            "get": {
                "description": "Basic liveness endpoint.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "probes"
                ],
                "summary": "Health",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/dto.ProbeResponse"
                        }
                    }
                }
            }
        },
        "/ping": {
            "get": {
                "description": "Lightweight ping endpoint.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "probes"
                ],
                "summary": "Ping",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/dto.ProbeResponse"
                        }
                    }
                }
            }
        },
        "/ready": {
            "get": {
                "description": "Readiness endpoint that checks database and Redis connectivity.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "probes"
                ],
                "summary": "Ready",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/dto.ProbeResponse"
                        }
                    },
                    "503": {
                        "description": "Service Unavailable",
                        "schema": {
                            "$ref": "#/definitions/dto.ProbeResponse"
                        }
                    }
                }
            }
        },
        "/v1/t/numbers": {
            "get": {
                "description": "Returns all stored numbers ordered ascending.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "tests/numbers"
                ],
                "summary": "List numbers",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/dto.ListEnvelope"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorEnvelope"
                        }
                    }
                }
            },
            "delete": {
                "description": "Deletes numbers passed in the `numbers` query parameter as comma-separated values.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "tests/numbers"
                ],
                "summary": "Delete numbers",
                "parameters": [
                    {
                        "type": "string",
                        "example": "1,2,3",
                        "description": "Comma-separated numbers",
                        "name": "numbers",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/dto.DeleteEnvelope"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorEnvelope"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorEnvelope"
                        }
                    }
                }
            }
        },
        "/v1/t/numbers/clear": {
            "delete": {
                "description": "Deletes all stored numbers.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "tests/numbers"
                ],
                "summary": "Clear numbers",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/dto.ClearEnvelope"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorEnvelope"
                        }
                    }
                }
            }
        },
        "/v1/t/numbers/random": {
            "get": {
                "description": "Returns one random stored number.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "tests/numbers"
                ],
                "summary": "Get random number",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/dto.NumberEnvelope"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorEnvelope"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorEnvelope"
                        }
                    }
                }
            }
        },
        "/v1/t/numbers/range": {
            "post": {
                "description": "Creates numbers in the inclusive range from `from` to `to`. Allowed range is 1..199.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "tests/numbers"
                ],
                "summary": "Create a range of numbers",
                "parameters": [
                    {
                        "description": "Range payload",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/dto.CreateRangeRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/dto.CreateRangeEnvelope"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorEnvelope"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorEnvelope"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "dto.ClearEnvelope": {
            "type": "object",
            "properties": {
                "data": {
                    "$ref": "#/definitions/dto.ClearResponse"
                }
            }
        },
        "dto.ClearResponse": {
            "type": "object",
            "properties": {
                "deleted": {
                    "type": "integer"
                }
            }
        },
        "dto.CreateRangeEnvelope": {
            "type": "object",
            "properties": {
                "data": {
                    "$ref": "#/definitions/dto.CreateRangeResponse"
                }
            }
        },
        "dto.CreateRangeRequest": {
            "type": "object",
            "properties": {
                "from": {
                    "type": "integer"
                },
                "to": {
                    "type": "integer"
                }
            }
        },
        "dto.CreateRangeResponse": {
            "type": "object",
            "properties": {
                "created": {
                    "type": "integer"
                },
                "from": {
                    "type": "integer"
                },
                "numbers": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/models.Number"
                    }
                },
                "to": {
                    "type": "integer"
                }
            }
        },
        "dto.DeleteEnvelope": {
            "type": "object",
            "properties": {
                "data": {
                    "$ref": "#/definitions/dto.DeleteResponse"
                }
            }
        },
        "dto.DeleteResponse": {
            "type": "object",
            "properties": {
                "deleted": {
                    "type": "integer"
                },
                "numbers": {
                    "type": "array",
                    "items": {
                        "type": "integer"
                    }
                }
            }
        },
        "dto.ListEnvelope": {
            "type": "object",
            "properties": {
                "data": {
                    "$ref": "#/definitions/dto.ListResponse"
                }
            }
        },
        "dto.ListResponse": {
            "type": "object",
            "properties": {
                "count": {
                    "type": "integer"
                },
                "numbers": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/models.Number"
                    }
                }
            }
        },
        "dto.NumberEnvelope": {
            "type": "object",
            "properties": {
                "data": {
                    "$ref": "#/definitions/models.Number"
                }
            }
        },
        "dto.ProbeResponse": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string"
                },
                "services": {
                    "type": "object",
                    "additionalProperties": {}
                },
                "status": {
                    "type": "string"
                }
            }
        },
        "models.Number": {
            "type": "object",
            "properties": {
                "id": {
                    "type": "string"
                },
                "number": {
                    "type": "integer"
                }
            }
        },
        "response.ErrorBody": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string"
                },
                "details": {},
                "message": {
                    "type": "string"
                }
            }
        },
        "response.ErrorEnvelope": {
            "type": "object",
            "properties": {
                "error": {
                    "$ref": "#/definitions/response.ErrorBody"
                }
            }
        }
    }
}